{
  "name": "resq-backend",
  "version": "1.0.0",
  "description": "Backend server for ResQ AI Productivity Companion",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "qa": "node -e \"const p=require('fs').existsSync('./backend/scripts/resqQualityCheck.js')?'./backend/scripts/resqQualityCheck.js':'./scripts/resqQualityCheck.js';process.exitCode=require('child_process').spawnSync('node',[p],{stdio:'inherit'}).status;\"",
    "prestart": "npm run qa"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "resend": "^6.14.0",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
