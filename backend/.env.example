# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/resq

# Authentication
JWT_SECRET=your_super_secret_jwt_key

# CORS / Client Redirects
CLIENT_URL=https://your-frontend-domain.web.app

# Google Gemini API (AI Features)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth (Calendar Integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-domain.a.run.app/api/google/callback

# ElevenLabs (Voice Synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Web Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@example.com

# Resend Email Service
RESEND_API_KEY=your_resend_api_key

# Razorpay Subscription Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Diagnostic Toggles
BYPASS_VOICE_GATE=false
